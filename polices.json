      "policyname": "question_media_auth_by_subscription",
      "permissive": "PERMISSIVE",
      "roles": "{authenticated}",
      "cmd": "SELECT",
      "qual": "(EXISTS ( SELECT 1\n   FROM ((questions q\n     JOIN test_series ts ON ((ts.id = q.test_series_id)))\n     LEFT JOIN profiles p ON ((p.id = auth.uid())))\n  WHERE ((q.id = question_media.question_id) AND ((ts.is_free = true) OR ((p.subscription_status = 'active'::text) AND (p.subscription_expiry > now()))))))",
      "with_check": null
    },
